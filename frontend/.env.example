# Copie para frontend/.env ou frontend/.env.local
#
# VITE_API_URL vazio (recomendado em dev e em vite preview):
#   o app usa URLs /api/... e o Vite encaminha para o backend (veja VITE_API_PROXY_TARGET).
# Produção em hospedagem estática SEM proxy: defina URL completa do backend.
# VITE_API_URL=https://api.seudominio.com
VITE_API_URL=

# Opcional: mesma chave do backend (API_KEY) se estiver ativa
# VITE_API_KEY=sua-chave-secreta

# Para onde o proxy encaminha /api (npm run dev e npm run preview)
# VITE_API_PROXY_TARGET=http://localhost:8000
