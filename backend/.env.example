# Opcional: protege todas as rotas /api/* (header X-API-Key).
# Se vazio ou ausente, a API não exige chave.
# API_KEY=sua-chave-secreta

# IA generativa (POST /api/ai/explain, POST /api/ai/query) — chave no servidor apenas, nunca no frontend.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TIMEOUT_SECONDS=60

# Treino do classificador (POST /api/ml/train-category-classifier)
# Em producao: false exige API_KEY no servidor (e header X-API-Key nas requisicoes).
# ALLOW_TRAINING_WITHOUT_API_KEY=true

# Limite de requisicoes /api/ai por IP (padrao 40/min). Desligar: AI_RATE_LIMIT_ENABLED=false
# AI_RATE_LIMIT_PER_MINUTE=40
# AI_RATE_LIMIT_ENABLED=true
